# Copy this file to config.properties and fill in your values.
# config.properties is gitignored — never commit real credentials.

db.url=jdbc:postgresql://localhost:5432/bookingsystemdb
db.username=your_db_user
db.password=your_db_password
db.driver=org.postgresql.Driver

# HikariCP Pool Settings
db.pool.maximumPoolSize=10
db.pool.minimumIdle=2
db.pool.idleTimeout=30000
db.pool.connectionTimeout=30000
db.pool.maxLifetime=600000
